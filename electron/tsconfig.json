{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": ["ES2022"],
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "../dist/electron",
    "rootDir": ".",
    "noEmitOnError": true,
    "types": ["node", "electron"]
  },
  "include": ["*.ts"]
}
